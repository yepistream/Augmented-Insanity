.python-version

# Ignore Nix files
result/
.direnv/

# Ignore direnv file (if you need this, create it yourself)
.envrc

# Kotlin
.kotlin

# ----------------------------------------------------------------------------
# Augmented Insanity additions
# ----------------------------------------------------------------------------

# External binary dependencies pulled by scripts/fetch-xr-deps.{ps1,sh}.
# Always downloaded, never committed. Removing it doesn't break the build --
# re-run the fetch script.
xr-deps/

# Per-module Gradle build outputs (Mercury/ARCore samples and the head-sway
# example each produce their own `build/` tree under their subproject root).
samples/*/build/
module-example/*/build/

# Per-module CMake artifacts (samples that use a standalone NDK CMake
# invocation drop these next to the sources).
samples/*/build/cmake/
module-example/*/build/cmake/

# Packaged module artifacts. `.augins` files are Release deliverables, not
# source. Building them in-tree should not commit them.
*.augins

# Local cache of fetched ONNX models, OpenCV SDK extracts, etc., even if a
# user opts to put them outside xr-deps/.
*.onnx
hand-tracking-models/

# OS / IDE noise
.DS_Store
Thumbs.db
.idea/

# Local override of fetch-xr-deps.ps1 paths
xr-deps-paths.local

